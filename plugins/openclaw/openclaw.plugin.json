{
  "id": "plugin-openclaw",
  "name": "RelAI Marketplace",
  "description": "Browse and call paid APIs on the RelAI marketplace. Agent key setup, API discovery, and metered API calls with automatic x402 payment.",
  "version": "0.1.2",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "description": "Base URL of the RelAI platform"
      },
      "requestTimeoutMs": {
        "type": "number",
        "description": "HTTP request timeout in milliseconds"
      },
      "chainType": {
        "type": "string",
        "enum": ["evm", "solana"],
        "description": "Chain type for agent key generation (evm or solana)"
      }
    }
  },
  "uiHints": {
    "baseUrl": {
      "label": "RelAI URL",
      "placeholder": "https://relai.fi"
    },
    "requestTimeoutMs": {
      "label": "Request timeout (ms)",
      "placeholder": "15000"
    },
    "chainType": {
      "label": "Chain Type",
      "placeholder": "evm"
    }
  }
}

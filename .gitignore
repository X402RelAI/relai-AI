# Dependencies (matches both real directories and symlinks — skill scripts
# sometimes symlink node_modules from a temp dir at runtime).
node_modules

# Build output
dist/
build/

# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# TypeScript
*.tsbuildinfo

# OpenClaw agent runtime state (per-session memory, purchase logs, etc.)
openclaw/agents/*/memory/
openclaw/agents/*/state/

# Personal OpenClaw config overrides (keep the example, ignore the real one)
openclaw/agents/*/openclaw.json
!openclaw/agents/*/openclaw.example.json

# Claude Code user-specific settings (permissions etc.) — not shared
.claude/settings.local.json

# Deps installed ad-hoc by skill scripts (consent.mjs dynamic imports)
.claude/skills/*/scripts/package-lock.json

# Service-key persistence — never commit if accidentally created inside the repo
**/.relai/
service-key.json

# Solana devnet keypairs generated by demo scripts (defense in depth — the
# shielded-link-demo also has a local .gitignore)
*-devnet.json
.buyer-devnet.json
.seller-devnet.json

# npm packaging artifacts
*.tgz

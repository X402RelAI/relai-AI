# Anthropic API key — both agents use Claude as their reasoning engine.
# Get one at https://console.anthropic.com — both agents share the same key
# but run as completely separate processes with independent context.
ANTHROPIC_API_KEY=sk-ant-api03-...

# RelAI API base. Default is the production Management API.
RELAI_BASE_URL=https://api.relai.fi

# Two RelAI service keys — one per agent. Each agent has its own consent
# (via the relai-setup skill or the dashboard) so they appear as two
# independent operators on the RelAI side.
#
# In SPR direction, the SELLER's service key issues + redeems the quote;
# the BUYER's service key is optional (pair endpoints are public — opaque
# quoteId acts as bearer) but recommended so HTTP errors surface cleanly.
RELAI_SERVICE_KEY_BUYER=sk-agent-...
RELAI_SERVICE_KEY_SELLER=sk-agent-...

# Buyer's Solana keypair — JSON array (canonical Solana CLI format) OR base58.
# Must hold devnet USDC (faucet: https://faucet.circle.com, network: Solana
# Devnet, OR hit POST /v1/shielded-payment-requests/solana-spr-faucet) and
# ≥ 0.001 SOL for gas (auto-airdropped on devnet by the buyer agent).
RELAI_BUYER_SOLANA_SECRET_KEY=[1,2,3,...]

# Seller's Solana keypair — required, NOT just a pubkey. SPR derives a
# per-quote stealth keypair from sha256(wallet.signMessage(challenge))
# so the seller's wallet keypair is bound by closure into the redeem
# tool (the LLM never sees it). The stealth claim tx (stealth ATA →
# main wallet ATA) is partial-signed by the stealth keypair; the
# operator co-signs as fee_payer.
RELAI_SELLER_SOLANA_SECRET_KEY=[1,2,3,...]

# Optional: override the frontend that hosts the SPR circuit artefacts.
# Defaults to https://relai.fi (which serves /zk/shielded-payment-{pairing,redeem}/...).
# RELAI_FRONTEND_URL=https://relai.fi

# Where the chat bus listens. Both agents connect here.
CHAT_BUS_PORT=4747

# Job parameters baked into the demo. Override to test different sizes.
DEMO_NETWORK=solana-devnet
DEMO_AMOUNT_USDC=0.1

# Optional — override the SPR pairing-circuit artefact URLs if your RelAI
# instance serves them at a non-default location. Defaults match the doc's
# convention `https://relai.fi/zk/shielded-payment-pairing/pairing.{wasm,zkey}`.
# SPR_PAIRING_WASM_URL=
# SPR_PAIRING_ZKEY_URL=
